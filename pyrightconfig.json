{
    "reportMissingImports": true,
    "reportMissingTypeStubs": false,
    // pyright options for MicroPython
    "reportMissingModuleSource": "none",
    "typeCheckingMode": "standard",
    // use custom typeshed for MicroPython 
    "typeshedPath": "./typings",
    // and for stdlib replacement
    "stubPath": "./typings",
    // standard locations
    "include": [
        "src",
    ],
    "extraPaths": [
        "src/lib"
        //     "/home/jos/mp_codemirror/src",
    ],
    "executionEnvironments": [
        {
            "root": ".",
            "extraPaths": [
                "src",
            ]
        },
        {
            "root": "/home/jos/mp_codemirror",
            "extraPaths": [
                "/home/jos/mp_codemirror/src",
            ]
        }
    ]
}